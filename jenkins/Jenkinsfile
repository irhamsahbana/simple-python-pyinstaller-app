node {
    checkout scm

    docker.image('python:3.11-alpine').inside('-u root:root') {
        stage('Build') {
            sh 'python3 -m py_compile sources/add2vals.py sources/calc.py'
        }

        stage('Test') {
            sh 'python3 -m pip install --user pytest'
            sh 'python3 -m pytest --verbose --junit-xml test-reports/results.xml sources/test_calc.py'
            junit 'test-reports/results.xml'
        }

        stage('Deliver') {
            sh 'apk add --no-cache binutils'
            sh 'python3 -m pip install --user pyinstaller'
            sh 'python3 -m PyInstaller --onefile sources/add2vals.py'
            archiveArtifacts 'dist/add2vals'
        }

        stage('Manual Approval') {
            input message: 'Lanjutkan ke tahap Deploy?'
        }

        stage('Deploy') {
            sh '''
                chmod +x dist/add2vals
                ( while true; do ./dist/add2vals 40 2; sleep 5; done ) &
                echo $! > .pidfile
            '''
            sleep(time: 60, unit: 'SECONDS')
            sh 'kill $(cat .pidfile) || true'
        }
    }
}
